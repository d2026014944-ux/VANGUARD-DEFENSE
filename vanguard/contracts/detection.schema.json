{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vanguard.local/contracts/detection.schema.json",
  "title": "VG-VISION BoundingBox Detection",
  "type": "object",
  "required": [
    "class",
    "confidence",
    "location"
  ],
  "properties": {
    "class": {
      "type": "string",
      "minLength": 1
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "location": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "number",
        "minimum": 0.0,
        "maximum": 1.0
      }
    },
    "lat": {
      "type": [
        "number",
        "null"
      ],
      "minimum": -90.0,
      "maximum": 90.0
    },
    "lon": {
      "type": [
        "number",
        "null"
      ],
      "minimum": -180.0,
      "maximum": 180.0
    },
    "hae": {
      "type": "number"
    }
  },
  "additionalProperties": false
}
